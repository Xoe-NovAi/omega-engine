# 🔱 Omega Engine — Environment Configuration Template
# AP: AP-ENV-EXAMPLE-v1.0.0
# Copy to .env and fill in your values
# Loaded by docker-compose.yml automatically

# ── Services ──────────────────────────────────────────────────────────
# Redis authentication password
REDIS_PASSWORD=changeme_redis_password
# PostgreSQL authentication password
POSTGRES_PASSWORD=changeme_postgres_password

# ── Ryzen 7 5700U CPU Optimization ───────────────────────────────────
# OpenMP thread count (set to number of physical cores, minus 2 for OS)
OMP_NUM_THREADS=6
# OpenMP thread binding policy
OMP_PROC_BIND=close
# OpenMP scheduling policy
OMP_SCHEDULE=STATIC
# OpenBLAS thread count
OPENBLAS_NUM_THREADS=6
# OpenBLAS CPU core type (ZEN for Ryzen)
OPENBLAS_CORETYPE=ZEN
# MKL thread count
MKL_NUM_THREADS=6
# NumExpr thread count
NUMEXPR_NUM_THREADS=6
# VecLib max threads
VECLIB_MAXIMUM_THREADS=6

# ── Podman ───────────────────────────────────────────────────────────
# Path to Podman socket (rootless user)
PODMAN_SOCKET=/run/user/1000/podman/podman.sock
# Container storage driver
STORAGE_DRIVER=overlay