# 🔱 Omega Engine — Environment Template
# Copy this file to .env and fill in your keys.
# DO NOT commit .env to git — it contains sensitive API keys.

# ── Model Inference ──────────────────────────────────────────────────────
# Primary: Google AI Studio (Gemma 4-31B)
GOOGLE_API_KEY=your_google_api_key_here

# Fallback: OpenCode Zen (MiniMax M2.5-free)
OPENCODEZEN=your_opencode_zen_key_here

# ── Search Providers ──────────────────────────────────────────────────────
EXA_API_KEY=your_exa_key_here
TAVILY_API_KEY=your_tavily_key_here
SERPER_API_KEY=your_serper_key_here

# ── Content Extraction ────────────────────────────────────────────────────
FIRECRAWL_API_KEY=your_firecrawl_key_here

# ── Optional: Cloud Fallback ──────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Infrastructure ────────────────────────────────────────────────────────
REDIS_PASSWORD=omega
POSTGRES_PASSWORD=omega

