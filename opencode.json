{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/home/arcana-novai/Documents/Xoe-NovAi/**": "allow",
      "/media/arcana-novai/**": "allow",
      "/home/arcana-novai/archive/**": "allow",
      "/home/arcana-novai/Documents/docs-backup/**": "allow",
      "/home/arcana-novai/Documents/docs_1/**": "allow",
      "/home/arcana-novai/Documents/Archives/**": "allow",
      "/home/arcana-novai/Documents/xnaif-files/**": "allow",
      "/home/arcana-novai/.lmstudio/**": "allow",
      "/home/arcana-novai/.ollama/**": "allow",
      "/home/arcana-novai/.config/opencode/**": "allow",
      "/tmp/omega/**": "allow"
    }
  },
  "instructions": [
    "SOVEREIGN_MANDATES.md",
    "ORACLE_STACK.md",
    "docs/strategy/MASTER_SYNTHESIS_AND_ROADMAP.md"
  ],
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/home/arcana-novai/Documents/Xoe-NovAi/omega-engine"],
      "enabled": false
    },
    "omega-hub": {
      "type": "remote",
      "url": "http://127.0.0.1:8016/sse",
      "enabled": true
    },
    "firecrawl": {
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"],
      "environment": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      },
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa",
      "headers": {
        "x-api-key": "${EXA_API_KEY}"
      },
      "enabled": true
    },
    "serper": {
      "type": "remote",
      "url": "https://mcp.serper.dev/mcp",
      "headers": {
        "x-api-key": "${SERPER_API_KEY}"
      },
      "enabled": false
    },
    "tavily": {
      "type": "local",
      "command": ["npx", "-y", "@tavily/mcp"],
      "environment": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "enabled": false
    },
    "jina": {
      "type": "remote",
      "url": "https://mcp.jina.ai/v1",
      "headers": {
        "Authorization": "Bearer ${JINA_API_KEY}"
      },
      "enabled": false
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "preserve_recent_tokens": 40000,
    "reserved": 10000
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (Local)",
      "options": {
        "baseURL": "http://localhost:1234/v1",
        "apiKey": "sk-local"
      },
      "models": {
        "qwen3-4b-thinking": {
          "id": "qwen3-4b-thinking",
          "name": "Qwen3 4B Thinking (local)",
          "limit": { "context": 8192, "output": 4096 }
        },
        "qwen3-1.7b": {
          "id": "qwen3-1.7b",
          "name": "Qwen3 1.7B (local)",
          "limit": { "context": 4096, "output": 2048 }
        },
        "qwen3-1.7b-q6_k": {
          "id": "qwen3-1.7b-q6_k",
          "name": "Qwen3 1.7B Q6_K (local)",
          "limit": { "context": 8192, "output": 4096 }
        },
        "phi-4-mini": {
          "id": "phi-4-mini",
          "name": "Phi-4 Mini (local)",
          "limit": { "context": 16384, "output": 4096 }
        },
        "krikri-8b": {
          "id": "krikri-8b",
          "name": "Krikri 8B (local)",
          "limit": { "context": 16384, "output": 4096 }
        },
        "deepseek-r1-qwen3-8b": {
          "id": "deepseek-r1-qwen3-8b",
          "name": "DeepSeek R1 Qwen3 8B (local)",
          "limit": { "context": 8192, "output": 4096 }
        }
      }
    }
  },
  "agent": {
